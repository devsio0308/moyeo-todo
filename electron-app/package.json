{
  "name": "moyeo-todo",
  "version": "1.1.0",
  "description": "게임 숙제 체크 오버레이 대시보드",
  "main": "./out/main/index.js",
  "author": "hrjin",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "build:all": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  },
  "repository": "https://github.com/devsio0308/moyeo-todo"
}
