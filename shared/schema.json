{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "homework-dashboard/shared/schema.json",
  "title": "숙제 대시보드 공용 스키마",
  "description": "electron-app ↔ web-overlay 간 공유되는 데이터 스키마.",
  "$defs": {
    "taskState": {
      "type": "object",
      "properties": {
        "done": { "type": "boolean" },
        "lastDoneAt": { "type": ["integer", "null"], "description": "unix epoch (초)" },
        "displayName": { "type": "string" },
        "period": { "enum": ["daily", "weekly"] },
        "catalogId": {
          "type": ["string", "null"],
          "description": "Firebase 카탈로그 출처 퀘스트의 문서 id (#4). 수동 추가는 null/없음"
        },
        "targetCount": {
          "type": "integer",
          "minimum": 1,
          "description": "완료에 필요한 횟수 (#7). 없으면 1 (단일 퀘스트)"
        },
        "count": {
          "type": "integer",
          "minimum": 0,
          "description": "현재 진행 횟수 (#7). 없으면 0"
        },
        "category": {
          "enum": ["전투", "물물교환", "알바", "구매", null],
          "description": "카테고리 태그 (#13). 없으면 배지 미표시. 배열 순서가 섹션 내 정렬 순서"
        },
        "location": {
          "type": ["string", "null"],
          "description": "지역 태그 (#24, 자유 문자열 — 예: 두갈드아일, 던바튼)"
        },
        "excluded": {
          "type": "boolean",
          "description": "이 캐릭터는 이 카탈로그 퀘스트를 하지 않음 (#25). true면 항상 완료 상태로 고정, 리셋 제외"
        }
      },
      "required": ["done", "lastDoneAt", "displayName", "period"]
    },
    "character": {
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "tasks": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/taskState" }
        }
      },
      "required": ["displayName", "tasks"]
    },
    "settings": {
      "type": "object",
      "properties": {
        "weeklyResetDay": { "type": "integer", "minimum": 0, "maximum": 6, "description": "0=일요일 ... 6=토요일" },
        "dailyResetHour": { "type": "integer", "minimum": 0, "maximum": 23 },
        "firebaseProjectId": {
          "type": ["string", "null"],
          "description": "퀘스트 카탈로그를 가져올 Firebase 프로젝트 ID (#4)"
        },
        "alarmModes": {
          "type": "object",
          "description": "알람 규칙별 모드 (#11). 키: 규칙 id (ominous-rift, field-boss)",
          "additionalProperties": { "enum": ["sound", "ui", "off"] }
        },
        "gameAccountId": {
          "type": ["string", "null"],
          "description": "게임계정 ID (#26) — Firestore players/{id} 문서와 동기화하는 키. 등록 시 캐릭터/퀘스트 진행 상황이 클라우드에 저장된다"
        }
      },
      "required": ["weeklyResetDay", "dailyResetHour"]
    },
    "storeShape": {
      "type": "object",
      "properties": {
        "characters": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/character" }
        },
        "characterOrder": {
          "type": "array",
          "items": { "type": "string" },
          "description": "탭 표시 순서 (characters의 키 목록)"
        },
        "settings": { "$ref": "#/$defs/settings" },
        "lastDailyResetAt": { "type": ["integer", "null"] },
        "lastWeeklyResetAt": { "type": ["integer", "null"] },
        "questCatalog": {
          "type": "array",
          "description": "마지막으로 동기화된 Firestore 퀘스트 카탈로그 캐시 (#4)",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "period": { "enum": ["daily", "weekly"] },
              "targetCount": { "type": "integer", "minimum": 1 },
              "category": { "enum": ["전투", "물물교환", "알바", "구매", null] },
              "location": { "type": ["string", "null"] }
            },
            "required": ["id", "name", "period"]
          }
        },
        "metaVersion": { "type": "integer", "description": "스토어 마이그레이션 버전 (내부용)" }
      },
      "required": ["characters", "characterOrder", "settings"]
    }
  }
}
